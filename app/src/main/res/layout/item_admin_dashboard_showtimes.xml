<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp">

    <ImageView
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/admin_icon_circle"
        android:padding="10dp"
        android:src="@android:drawable/ic_menu_recent_history"
        android:tint="@color/admin_accent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quản lý Suất Chiếu"
            android:textColor="@color/admin_text_primary"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lịch chiếu và khung giờ"
            android:textColor="@color/admin_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/ic_media_next"
        android:tint="@color/admin_text_secondary" />
</LinearLayout>
