<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/admin_surface_card"
    android:padding="16dp"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp">

    <!-- Row with labels and prices -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        
        <!-- Indicator Dot -->
        <View
            android:id="@+id/viewColorIndicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_indicator"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMovieTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Movie Title"
                android:textColor="@color/admin_text_primary"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvTicketCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 vé (0%)"
                android:textColor="@color/admin_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvRevenue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0₫"
            android:textColor="@color/admin_warning"
            android:textStyle="bold"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Progress Indicator -->
    <ProgressBar
        android:id="@+id/progressBarShare"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="12dp"
        android:progress="0"
        android:max="100"
        android:progressDrawable="@drawable/custom_progress_bar_horizontal" />
</LinearLayout>
