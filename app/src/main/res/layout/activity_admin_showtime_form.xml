<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/admin_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/admin_header"
        android:padding="16dp"
        android:paddingTop="36dp">

        <ImageButton
            android:id="@+id/backBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/admin_text_primary"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/titleBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thêm suất chiếu"
            android:textColor="@color/admin_text_primary"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== PHẦN CHỌN PHIM ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn phim *"
                android:textColor="@color/admin_text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardSelectMovie"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/admin_surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/ivSelectedMoviePoster"
                        android:layout_width="60dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_launcher_foreground"
                        android:scaleType="centerCrop"
                        android:contentDescription="Movie poster"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/light_black_bg" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvSelectedMovieTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Chưa chọn phim"
                            android:textColor="@color/admin_text_primary"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/tvSelectedMovieYear"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/admin_text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== PHẦN CHỌN PHÒNG CHIẾU ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn phòng chiếu *"
                android:textColor="@color/admin_text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerRoom"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/admin_input_bg"
                android:paddingStart="10dp"
                android:spinnerMode="dropdown"
                android:popupBackground="@color/admin_surface"
                android:layout_marginBottom="14dp" />

            <!-- ===== PHẦN CHỌN NGÀY CHIẾU ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn ngày chiếu *"
                android:textColor="@color/admin_text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/tvScreeningDate"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Chưa chọn"
                    android:textColor="@color/admin_text_primary"
                    android:gravity="center_vertical"
                    android:background="@drawable/admin_input_bg"
                    android:paddingStart="14dp"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnPickDate"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Chọn"
                    android:textColor="@color/admin_text_primary"
                    android:background="@drawable/admin_button_primary"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- ===== PHẦN CHỌN KHUNG GIỜ ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn khung giờ *"
                android:textColor="@color/admin_text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTimeSlots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:minHeight="150dp"
                android:scrollbars="vertical" />

            <!-- Price tier info -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/admin_surface_alt"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <TextView
                    android:id="@+id/tvPriceTier"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Khung giờ: Chưa xác định"
                    android:textColor="@color/admin_warning"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:padding="14dp"
                    android:gravity="center" />

            </androidx.cardview.widget.CardView>

            <!-- Save button -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Lưu suất chiếu"
                android:textColor="@color/admin_text_primary"
                android:textStyle="bold"
                android:textSize="16sp"
                android:background="@drawable/admin_button_primary"
                android:layout_marginBottom="32dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
