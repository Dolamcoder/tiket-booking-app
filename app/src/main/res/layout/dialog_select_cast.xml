<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/admin_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/admin_header"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chọn diễn viên"
            android:textColor="@color/admin_text_primary"
            android:textStyle="bold"
            android:textSize="18sp" />

        <ImageButton
            android:id="@+id/btnCloseCastDialog"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/admin_text_primary" />
    </LinearLayout>

    <!-- Search bar -->
    <EditText
        android:id="@+id/etSearchCast"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Tìm kiếm diễn viên..."
        android:textColorHint="@color/admin_text_secondary"
        android:textColor="@color/admin_text_primary"
        android:background="@drawable/admin_input_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:inputType="text"
        android:layout_margin="12dp" />

    <!-- RecyclerView for cast list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewSelectCast"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:background="@color/admin_header"
        android:padding="12dp">

        <Button
            android:id="@+id/btnCancelSelectCast"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Hủy"
            android:textSize="13sp"
            android:background="@drawable/admin_button_secondary"
            android:textColor="@color/admin_text_primary"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnConfirmSelectCast"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Chọn"
            android:textSize="13sp"
            android:background="@drawable/admin_button_primary"
            android:textColor="@color/admin_text_primary" />
    </LinearLayout>
</LinearLayout>

