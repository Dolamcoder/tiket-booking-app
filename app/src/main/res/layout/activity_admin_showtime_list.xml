<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/admin_bg">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/admin_header"
        android:padding="16dp"
        android:paddingTop="36dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="Back"
            android:padding="8dp"
            android:background="@drawable/rounded_button_semi_black"
            android:tint="@android:color/white"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/back_dark"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎬 Quản lý Suất Chiếu"
            android:textColor="@color/admin_text_primary"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Filter Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/admin_header"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:layout_marginTop="88dp"
        android:elevation="2dp">

        <!-- Chọn film -->
        <Button
            android:id="@+id/btnSelectMovie"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🎥 Film"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/admin_button_secondary"
            android:textColor="@color/admin_text_primary"
            android:layout_marginEnd="8dp"
            android:stateListAnimator="@animator/button_press" />

        <!-- Khung giờ spinner -->
        <Spinner
            android:id="@+id/spinnerTimeSlot"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/admin_input_bg"
            android:spinnerMode="dropdown"
            android:popupBackground="@color/admin_surface"
            android:layout_marginEnd="8dp" />

        <!-- Xóa lọc -->
        <Button
            android:id="@+id/btnClearFilter"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="✖"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@color/admin_danger"
            android:textColor="@color/white"
            android:minWidth="44dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:stateListAnimator="@animator/button_press" />
    </LinearLayout>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewShowtimes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="170dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false" />

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddShowtime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/ic_add_showtime"
        app:backgroundTint="@color/admin_accent"
        app:tint="@color/admin_text_primary"
        app:fabSize="normal"
        android:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
