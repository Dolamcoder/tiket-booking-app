<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/admin_surface_card"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thêm diễn viên mới"
        android:textColor="@color/admin_text_primary"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

    <!-- Ảnh diễn viên -->
    <androidx.cardview.widget.CardView
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        android:id="@+id/cardCastImage"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <ImageView
            android:id="@+id/imgCastPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery" />
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnPickCastImage"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:text="Chọn ảnh"
        android:textSize="13sp"
        android:background="@drawable/admin_button_secondary"
        android:textColor="@color/admin_text_primary" />

    <!-- Tên diễn viên -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tên diễn viên *"
        android:textColor="@color/admin_text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etCastName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Nhập tên diễn viên"
        android:textColorHint="@color/admin_text_secondary"
        android:textColor="@color/admin_text_primary"
        android:background="@drawable/admin_input_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:inputType="text"
        android:layout_marginBottom="20dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnCancelAddCast"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Hủy"
            android:textSize="13sp"
            android:background="@drawable/admin_button_secondary"
            android:textColor="@color/admin_text_primary"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnConfirmAddCast"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Thêm"
            android:textSize="13sp"
            android:background="@drawable/admin_button_primary"
            android:textColor="@color/admin_text_primary" />
    </LinearLayout>
</LinearLayout>

