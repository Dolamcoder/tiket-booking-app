<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:foreground="?attr/selectableItemBackground">

    <!-- Movie poster -->
    <ImageView
        android:id="@+id/ivMoviePoster"
        android:layout_width="60dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_launcher_foreground"
        android:scaleType="centerCrop"
        android:contentDescription="Movie poster"
        android:layout_marginEnd="12dp"
        android:background="@drawable/light_black_bg" />

    <!-- Movie info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvMovieTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Movie Title"
            android:textColor="@color/admin_text_primary"
            android:textStyle="bold"
            android:textSize="15sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvMovieYear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2026"
            android:textColor="@color/admin_text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Selection indicator -->
    <ImageView
        android:id="@+id/ivCheck"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_save"
        android:tint="@color/admin_accent"
        android:layout_marginStart="8dp"
        android:visibility="gone"
        android:contentDescription="Selected" />

</LinearLayout>



