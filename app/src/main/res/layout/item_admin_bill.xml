<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/admin_surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Bill ID and Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvBillId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bill #ABC123"
                android:textColor="@color/admin_text_primary"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã thanh toán"
                android:textColor="@color/admin_success"
                android:textSize="13sp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@drawable/admin_chip_neutral" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/admin_border"
            android:layout_marginVertical="8dp" />

        <!-- Row 2: Booking Time -->
        <TextView
            android:id="@+id/tvBookingTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đặt lúc: 14/04/2025 19:30"
            android:textColor="@color/admin_text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <!-- Row 3: Seats -->
        <TextView
            android:id="@+id/tvSeats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ghế: A1, A2, A3"
            android:textColor="@color/admin_text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <!-- Row 4: Total Price -->
        <TextView
            android:id="@+id/tvTotalPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tổng: 300.000đ"
            android:textColor="@color/admin_warning"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- Button Cancel -->
        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Cancel Bill"
            android:textColor="@color/admin_text_primary"
            android:textStyle="bold"
            android:background="@drawable/admin_button_danger"
            android:textSize="14sp"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>

</androidx.cardview.widget.CardView>


