<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/admin_surface_card"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thêm thể loại mới"
        android:textColor="@color/admin_text_primary"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

    <!-- Tên thể loại -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tên thể loại *"
        android:textColor="@color/admin_text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etGenreName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Nhập tên thể loại (vd: Hành động, Kinh dị...)"
        android:textColorHint="@color/admin_text_secondary"
        android:textColor="@color/admin_text_primary"
        android:background="@drawable/admin_input_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:inputType="text"
        android:layout_marginBottom="20dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnCancelAddGenre"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Hủy"
            android:textSize="13sp"
            android:background="@drawable/admin_button_secondary"
            android:textColor="@color/admin_text_primary"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnConfirmAddGenre"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Thêm"
            android:textSize="13sp"
            android:background="@drawable/admin_button_primary"
            android:textColor="@color/admin_text_primary" />
    </LinearLayout>
</LinearLayout>

