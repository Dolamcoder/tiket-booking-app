<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/admin_surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Movie Name -->
        <TextView
            android:id="@+id/tvMovieName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên phim"
            android:textColor="@color/admin_text_primary"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginBottom="4dp" />

        <!-- Room Name -->
        <TextView
            android:id="@+id/tvRoomName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phòng chiếu"
            android:textColor="@color/admin_text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/admin_border"
            android:layout_marginBottom="8dp" />

        <!-- Start Time -->
        <TextView
            android:id="@+id/tvStartTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bắt đầu: 14/04/2025 19:00"
            android:textColor="@color/admin_text_primary"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <!-- End Time -->
        <TextView
            android:id="@+id/tvEndTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kết thúc: 14/04/2025 21:00"
            android:textColor="@color/admin_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <!-- Price Tier + Booked count row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvPriceTier"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Khung giờ: Tối"
                android:textColor="@color/admin_warning"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvBookedSeats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Đã đặt: 25"
                android:textColor="@color/admin_danger"
                android:textStyle="bold"
                android:textSize="12sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/admin_border"
            android:layout_marginBottom="10dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnDetail"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Chi tiết"
                android:textColor="@color/admin_text_primary"
                android:textStyle="bold"
                android:background="@drawable/admin_button_secondary"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btnEdit"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Sửa"
                android:textColor="@color/admin_text_primary"
                android:textStyle="bold"
                android:background="@drawable/admin_button_primary"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Xóa"
                android:textColor="@color/admin_text_primary"
                android:textStyle="bold"
                android:background="@drawable/admin_button_danger"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
